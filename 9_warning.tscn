[node name="Label" type="Label" parent="Control"]
layout_mode = 2
offset_right = 896.0
offset_bottom = 599.0
text = "There is a boss battle in this game. The battle works the same as normal Minesweeper, but with some key distinctions: you won't know the number of mines hidden on the grid, you have limited time to complete the level, and you won't be able to use the sonar or pause the game. Clicking on a mine will make the time run out faster. To win, you must click on the boss ONLY AFTER revealing all the tiles that don't contain mines. If the timer hits 0, or you click on the boss before revealing the entire grid, it's game over. These instructions have now been added to the 'Special Rules' in the 'How To Play' guide accessible from the Title Screen."
label_settings = SubResource("LabelSettings_ye7cg")
horizontal_alignment = 1
vertical_alignment = 1
autowrap_mode = 3

