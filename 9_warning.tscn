[node name="Label" type="Label" parent="Control3"]
layout_mode = 2
offset_right = 896.0
offset_bottom = 599.0
text = "There is yet another boss battle in this game. The top left number now shows how many more tiles are allowed to be flagged before it's game over. The boss will teleport around the grid placing flags. If you can click the boss before it materializes, you can prevent it from placing a flag, but don't click the boss when its electrical coils are active or you will receive a penalty. Unflagging tiles before the game starts will also result in a penalty. Furthermore, the mines in this boss's grid are pressure mines. Do not remove flags from tiles that contain pressure mines. The boss will place many flags in quick succession if a mine is revealed. To win, reveal the entire grid before the flag counter reaches 0, or before no more flags can be placed on the grid. These instructions have now been added to the 'Special Rules' in the 'How To Play' guide accessible from the Title Screen."
label_settings = SubResource("LabelSettings_ye7cg")
horizontal_alignment = 1
vertical_alignment = 1
autowrap_mode = 3

