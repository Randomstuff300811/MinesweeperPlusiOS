[node name="Label" type="Label" parent="Control2"]
layout_mode = 2
offset_right = 896.0
offset_bottom = 599.0
text = "There is another boss battle in this game. As soon as the game starts, this boss will start counting down from 10. If it counts all the way down to 0, it's game over. Click on the boss to reset the countdown back to 10, but be careful. The boss will move faster and faster every time you click on it. Clicking on a mine will cause the boss to count down more quickly. To win, reveal the entire grid before the boss is able to finish its countdown. These instructions have now been added to the 'Special Rules' in the 'How To Play' guide accessible from the Title Screen."
label_settings = SubResource("LabelSettings_ye7cg")
horizontal_alignment = 1
vertical_alignment = 1
autowrap_mode = 3

