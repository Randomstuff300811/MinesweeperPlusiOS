[node name="HelpLabel" type="Label" parent="AdventureModeScreen/HelpButton/Help"]
anchors_preset = 7
anchor_left = 0.5
anchor_top = 1.0
anchor_right = 0.5
anchor_bottom = 1.0
offset_right = 896.0
offset_bottom = 640.0
grow_horizontal = 2
grow_vertical = 0
text = "GAMEPLAY MODES:

Normal: The way the game was meant to be played. Three mistakes allowed, continues double in price for every defeat, and sonar costs increase every time it is used per level. Gameplay is ranked.

Casual: For players who want a less stressful minesweeping experience. Three mistakes are allowed per level, and health is restored after every level. Continue costs are free, and continuing grants you shields (3 max). The first sonar use per level is free, and then stays at its base price for the rest of the level. Gameplay is not ranked.

Boss Pursuit: An experimental new game mode that is not for the faint of heart. Unlocks after winning an episode on Normal mode for each difficulty. Your foes have returned, and they want revenge. Gameplay is ranked."
label_settings = ExtResource("19")
horizontal_alignment = 1
vertical_alignment = 1
autowrap_mode = 3

